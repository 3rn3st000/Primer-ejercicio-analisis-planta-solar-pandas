   "source": [
    "def fueraRango(valor, min_val, max_val):\n",
    "    if valor < min_val or valor > max_val:\n",
    "        return np.nan\n",
    "    return valor\n",
    "        \n",
    "datosUnidos['DC_POWER'] = datosUnidos['DC_POWER'].apply(\n",
    "    fueraRango, \n",
    "    min_val=0, \n",
    "    max_val=15000\n",
    ")"
   ]
